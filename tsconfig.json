{
    "compilerOptions": {
        "baseUrl": "./",
        "moduleResolution": "node",
        "ignoreDeprecations": "6.0",
        "module": "commonjs",
        "target": "es2015",
        "strict": true,
        "noImplicitAny": true,
        "sourceMap": true,
        "declaration": true,
        "rootDir": "./src",
        "outDir": "dist/",
        "experimentalDecorators": true,
        "emitDecoratorMetadata": true,
        "importHelpers": true,
        "lib":  ["es2015"] 
    },
    "include": [
        "src/**/*"
    ],
    "exclude": [
        "node_modules",
        "typings/global",
        "typings/global.d.ts",
        "src/**/*.spec.ts"
    ]
}